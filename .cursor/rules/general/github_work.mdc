### Шаг 3: Получение обновлений на prod сервере (95.163.230.61)

```bash
# Подключиться к prod серверу
ssh root@95.163.230.61

# Перейти в директорию проекта
cd /opt/civilx-universe

# Проверить текущий статус
git status

# Проверить, что remote настроен
git remote -v
# Должен быть:
# synch   https://github.com/F1bonacci66/civilxuniverse.synch.git

# Получить последние изменения
git pull synch main

# Если есть конфликты, разрешить их
# git merge synch/main
# или
# git rebase synch/main

# ВАЖНО: После git pull проверить и инициализировать .env файлы
# Frontend
cd /opt/civilx-universe/universe/universe
if [ -f init-prod-env.sh ]; then
    chmod +x init-prod-env.sh
    ./init-prod-env.sh
else
    echo "⚠️  Скрипт init-prod-env.sh не найден, создайте .env вручную"
fi

# Backend (если нужно)
cd /opt/civilx-backend
if [ ! -f .env ]; then
    echo "⚠️  Backend .env не найден! Создайте его вручную."
fi
```

**Если remote не настроен**:
```bash
# Добавить remote для синхронизации
git remote add synch https://github.com/F1bonacci66/civilxuniverse.synch.git

# Получить изменения
git pull synch main
```

---

### Шаг 4: Применение изменений на prod сервере

```bash
# На prod сервере после git pull

# ВАЖНО: Проверить .env файлы (они НЕ коммитятся в Git)
# Если .env файлы отсутствуют, создать их из шаблонов

# Проверить Backend .env
cd /opt/civilx-backend
if [ ! -f .env ]; then
    echo "⚠️  Backend .env не найден! Создайте его вручную."
    echo "См. раздел 'Настройка переменных окружения' ниже"
fi

# Проверить Frontend .env (используем скрипт инициализации)
cd /opt/civilx-universe/universe/universe
if [ ! -f .env ]; then
    if [ -f init-prod-env.sh ]; then
        echo "Запускаю скрипт инициализации .env..."
        chmod +x init-prod-env.sh
        echo "y" | ./init-prod-env.sh
    else
        echo "⚠️  Frontend .env не найден и скрипт init-prod-env.sh недоступен!"
        echo "Создайте .env вручную. См. раздел 'Настройка переменных окружения' ниже"
    fi
fi

# Для Backend (если изменился код)
cd /opt/civilx-backend
docker-compose restart

# Или пересоздать контейнер
docker-compose down
docker-compose up -d --build

# Для Frontend (если изменился код)
cd /opt/civilx-universe
docker-compose restart

# Или пересоздать контейнер
docker-compose down
docker-compose up -d --build
```

